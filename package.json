{
  "name": "timesheet-sst",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -f .env.local -- next dev",
    "build": "dotenvx run -f .env.local -- next build",
    "start": "dotenvx run -f .env.local -- next start",
    "lint": "edotenvx slint",
    "storybook": "dotenvx run -f .env.local -- storybook dev -p 6006 --no-open",
    "build-storybook": "dotenvx run -f .env.local -- storybook build",
    "test:vitest:run": "dotenvx run -f .env.local -- vitest run",
    "test:vitest:watch": "dotenvx run -f .env.local -- vitest",
    "db:generate": "dotenvx run -f .env.local -- drizzle-kit generate",
    "db:push": "dotenvx run -f .env.local -- drizzle-kit push",
    "db:migrate": "dotenvx run -f .env.local -- drizzle-kit migrate",
    "db:pull": "dotenvx run -f .env.local -- drizzle-kit pull",
    "db:check": "dotenvx run -f .env.local -- drizzle-kit check",
    "db:studio": "dotenvx run -f .env.local -- drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "got": "^14.6.6",
    "input-otp": "^1.4.2",
    "neverthrow": "^8.2.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@storybook/nextjs-vite": "^10.2.13",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-storybook": "^10.2.13",
    "jsdom": "^28.1.0",
    "nock": "^14.0.11",
    "storybook": "^10.2.13",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
